# AI Captain - Environment Variables

# Optional: Set your AI Gateway API key
# Leave this empty to use mock mode (demo responses)
AI_GATEWAY_API_KEY=

# Optional: Specify which AI model to use
# Default: openai/gpt-4o-mini
# Other examples: anthropic/claude-opus-4, google/gemini-2-flash
AI_MODEL=openai/gpt-4o-mini

# App Configuration
# Use "demo" for local mock responses or "live" to enable the streamed AI route
NEXT_PUBLIC_APP_MODE=demo
